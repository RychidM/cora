{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "type": "command",
        "bash": "node ~/.agentwatch/hook.js",
        "timeoutSec": 130
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "node ~/.agentwatch/hook.js",
        "timeoutSec": 10
      }
    ],
    "sessionStart": [
      {
        "type": "command",
        "bash": "node ~/.agentwatch/hook.js",
        "timeoutSec": 10
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "node ~/.agentwatch/hook.js",
        "timeoutSec": 10
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "node ~/.agentwatch/hook.js",
        "timeoutSec": 10
      }
    ]
  }
}
