{
  "name": "cora",
  "displayName": "CORA",
  "version": "1.0.1",
  "description": "CORA (Continuity Of Recorded Activity) — skills and slash commands for managing your Obsidian-based memory vault with any Claude agent. Capture ideas and decisions via propose-then-write, init projects, sync agent files, and search the vault — all from chat.",
  "author": {
    "name": "RM",
    "url": "https://github.com/RychidM"
  },
  "license": "MIT",
  "repository": "https://github.com/RychidM/cora",
  "homepage": "https://github.com/RychidM/cora#readme",
  "keywords": [
    "cora",
    "obsidian",
    "memory",
    "vault",
    "agent",
    "knowledge-management",
    "claude-code",
    "claude-desktop"
  ],
  "compatibility": {
    "claude-code": ">=1.0.0",
    "claude-desktop": ">=1.0.0"
  },
  "config": {
    "vault_path_env": "AGENT_MEMORY_VAULT",
    "vault_path_fallback": "$HOME/Library/Mobile Documents/iCloud~md~obsidian/Documents/rm-memory-vault"
  }
}
